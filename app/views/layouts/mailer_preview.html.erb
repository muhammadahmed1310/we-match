<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || @page_title || "Mailer Previews" %> · WE Match</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Fraunces:opsz,wght@9..144,500;9..144,600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="site-body">
    <div class="site-backdrop" aria-hidden="true"></div>

    <%= render "shared/header" %>

    <main class="page-content container mailer-preview-page" data-controller="page">
      <div class="page-content__inner is-visible" data-page-target="content">
        <nav class="mailer-preview-breadcrumb" aria-label="Breadcrumb">
          <%= link_to "← Back to app", root_path, class: "mailer-preview-breadcrumb__link" %>
          <span class="mailer-preview-breadcrumb__sep">/</span>
          <%= link_to "Mailer previews", url_for(controller: "rails/mailers", action: "index"), class: "mailer-preview-breadcrumb__link" %>
          <%= yield :breadcrumb %>
        </nav>

        <%= yield %>
      </div>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
