<%= form_with model: [ @match_cycle, match_response ], local: true do |form| %>
  <% if match_response.errors.any? %>
    <div class="form-errors">
      <ul>
        <% match_response.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :member_id, "Member" %>
    <%= form.collection_select :member_id, @members, :id, :name, prompt: "Select yourself" %>
  </div>

  <div class="form-group">
    <%= form.label :topic, "Topic you'd like to discuss" %>
    <%= form.text_field :topic, placeholder: "e.g. Leadership, Career Transitions" %>
  </div>

  <div class="form-group">
    <%= form.label :availability_start, "Availability start (UTC)" %>
    <%= form.datetime_local_field :availability_start %>
  </div>

  <div class="form-group">
    <%= form.label :availability_end, "Availability end (UTC)" %>
    <%= form.datetime_local_field :availability_end %>
  </div>

  <div class="actions">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", match_cycle_path(@match_cycle), class: "btn btn-secondary" %>
  </div>
<% end %>
